{
  "manifest_version": 2,
  "name": "FocusFlow - Controle de Produtividade",
  "version": "1.0",
  "description": "Extensão para promoção de foco e combate ao cyberslacking baseada em nudges.",
  "permissions": [
    "storage",
    "tabs",
    "webNavigation",
    "activeTab",
    "<all_urls>"
  ],
  
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": false
  },

  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.svg",
      "48": "icon.svg",
      "128": "icon.svg"
    }
  },

  "icons": {
    "16": "icon.svg",
    "48": "icon.svg",
    "128": "icon.svg"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "focusflow@tcc.com",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  }
}